generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id                 String              @id @default(cuid())
  registration       String              @unique
  make               String
  model              String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  driverId           String?             @unique
  latitude           Float?
  longitude          Float?
  status             String              @default("AVAILABLE")
  capacityKg         Float?
  capacityM3         Float?
  fuelType           String              @default("DIESEL")
  hasColdChain       Boolean             @default(false)
  insuranceExpiresAt DateTime?
  nextServiceDate    DateTime?
  odometerKm         Int?
  type               String              @default("VAN_SMALL")
  year               Int?
  fuelEntries        FuelEntry[]
  maintenanceRecords MaintenanceRecord[]
  orders             Order[]
  telematicsEvents   TelematicsEvent[]
  driver             Driver?             @relation(fields: [driverId], references: [id])
}

model Driver {
  id               String        @id @default(cuid())
  email            String        @unique
  phone            String?
  createdAt        DateTime      @default(now())
  name             String
  updatedAt        DateTime      @updatedAt
  status           String        @default("ACTIVE")
  licenseExpiresAt DateTime?
  licenseNumber    String?
  rating           Float?
  totalDeliveries  Int           @default(0)
  shifts           DriverShift[]
  orders           Order[]
  vehicle          Vehicle?
}

model DriverShift {
  id        String    @id @default(cuid())
  driverId  String
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  startKm   Int?
  endKm     Int?
  notes     String?
  driver    Driver    @relation(fields: [driverId], references: [id])

  @@index([driverId])
}

model Order {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  customerEmail   String
  customerName    String
  customerPhone   String
  deliveryAddress String
  driverId        String?
  driverName      String?
  orderNumber     String    @unique
  pickupAddress   String
  priority        String    @default("NORMAL")
  scheduledDate   DateTime?
  vehicleId       String?
  status          String    @default("PENDING")
  completedAt     DateTime?
  podNote         String?
  podPhotoUrl     String?
  driver          Driver?   @relation(fields: [driverId], references: [id])
  vehicle         Vehicle?  @relation(fields: [vehicleId], references: [id])
}

model Warehouse {
  id           String          @id @default(cuid())
  name         String
  address      String
  capacity     Int
  createdAt    DateTime        @default(now())
  currentStock Int             @default(0)
  location     String
  manager      String?
  phone        String?
  updatedAt    DateTime        @updatedAt
  latitude     Float?
  longitude    Float?
  items        InventoryItem[]
  zones        WarehouseZone[]
}

model WarehouseZone {
  id          String    @id @default(cuid())
  warehouseId String
  code        String
  name        String
  type        String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([warehouseId, code])
}

model InventoryItem {
  id          String              @id @default(cuid())
  sku         String              @unique
  category    String
  createdAt   DateTime            @default(now())
  maxStock    Int                 @default(1000)
  minStock    Int                 @default(0)
  name        String
  quantity    Int
  unitPrice   Float
  updatedAt   DateTime            @updatedAt
  warehouseId String
  unitCost    Float?
  weight      Float?
  warehouse   Warehouse           @relation(fields: [warehouseId], references: [id])
  movements   InventoryMovement[]
}

model InventoryMovement {
  id        String        @id @default(cuid())
  itemId    String
  type      String
  quantity  Int
  reference String?
  notes     String?
  createdAt DateTime      @default(now())
  item      InventoryItem @relation(fields: [itemId], references: [id])

  @@index([itemId])
}

model MaintenanceRecord {
  id              String    @id @default(cuid())
  vehicleId       String
  type            String
  description     String
  cost            Float?
  odometerKm      Int?
  performedAt     DateTime
  performedBy     String?
  nextServiceKm   Int?
  nextServiceDate DateTime?
  status          String    @default("SCHEDULED")
  priority        String    @default("NORMAL")
  createdAt       DateTime  @default(now())
  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
}

model FuelEntry {
  id           String   @id @default(cuid())
  vehicleId    String
  driverId     String?
  date         DateTime @default(now())
  litres       Float
  costPerLitre Float?
  totalCost    Float
  station      String?
  odometerKm   Int?
  createdAt    DateTime @default(now())
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
}

model TelematicsEvent {
  id           String   @id @default(cuid())
  vehicleId    String
  timestamp    DateTime @default(now())
  latitude     Float
  longitude    Float
  speedKmh     Float?
  heading      Float?
  ignition     Boolean?
  fuelLevelPct Float?
  odometerKm   Float?
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId, timestamp])
}

model AuditLog {
  id         String   @id @default(cuid())
  actor      String
  actorType  String   @default("user")
  action     String
  resource   String
  resourceId String
  before     Json?
  after      Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([resource, resourceId])
}

model Shipper {
  id          String   @id
  legalName   String
  email       String   @unique
  phone       String?
  address     String?
  contactName String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}
